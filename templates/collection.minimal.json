{
  "sections": {
    "header": {
      "type": "collection-banner",
      "settings": {
        "color_scheme": "scheme-2",
        "image": "{{ collection.image }}",
        "mobile_image": "{{ collection.image }}",
        "image_size": "auto",
        "allow_transparent_header": false,
        "show_image": false,
        "reveal": true,
        "enable_parallax": false,
        "show_collection_title": true,
        "show_collection_description": true,
        "show_breadcrumb": true,
        "content_width": "xs",
        "text_alignment": "center",
        "overlay_color": "#000000",
        "overlay_opacity": 0
      }
    },
    "main": {
      "type": "main-collection",
      "settings": {
        "color_scheme": "scheme-2",
        "hide_product_information": false,
        "products_per_page": 48,
        "products_per_row_mobile": "2",
        "products_size_desktop": "large",
        "show_grid_mode_selector": false,
        "horizontal_spacing_factor": 1.7,
        "vertical_spacing_factor": 1.7,
        "filter_layout": "drawer",
        "quick_links_menu": "",
        "show_sort_by": true,
        "show_filters": true,
        "show_results_count": true,
        "show_filter_group_name": false,
        "show_filter_values_count": false,
        "open_filters_by_default": false
      }
    }
  },
  "order": [
    "header",
    "main"
  ]
}
